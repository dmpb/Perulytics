DATABASE_URL="postgresql://postgres:postgres@localhost:5432/perulytics?schema=public"
# En Docker Compose, el host es "db":
# DATABASE_URL="postgresql://postgres:postgres@db:5432/perulytics?schema=public"
PORT=3000
ONPE_ELECTION_ID=10
ONPE_TIPO_FILTRO=eleccion
# Opcional: copia Cookie desde el navegador si ONPE bloquea requests server-to-server.
ONPE_COOKIE=
# Alternativa recomendada (evita problemas con caracteres especiales como "$" o ";"):
# ONPE_COOKIE_BASE64=$(echo -n "_ga=...; _clck=...; ..." | base64 -w0)
ONPE_COOKIE_BASE64=
